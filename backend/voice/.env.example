# Clutch Voice Crisis Mode worker - environment.
# Copy to .env in the backend/ directory and fill in your values.

# --- LiveKit (Cloud or self-hosted) ---
# Create a free project at https://cloud.livekit.io, then copy these from its
# "Keys" page. The same three values must also be set on the Clutch API so the
# /voice/token endpoint can mint matching access tokens.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Google AI Studio (Gemini Live) ---
# The Gemini Live native-audio model needs a Google AI Studio API key.
GOOGLE_API_KEY=your_gemini_api_key

# --- Clutch API the worker drives ---
# Point this at the running Clutch backend. The voice agent calls it over HTTP
# so it reuses all planning / triage / renegotiation logic.
CLUTCH_API_BASE=http://localhost:8000

# --- Optional overrides (defaults shown) ---
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
# GEMINI_LIVE_VOICE=Charon
# CLUTCH_API_TIMEOUT=90
