# Base URL of the Clutch FastAPI backend.
# Local dev default is http://localhost:8000 (see src/api.ts).
VITE_CLUTCH_API_BASE=http://localhost:8000

# Optional: override the LiveKit server URL used by Voice Crisis Mode.
# Not required - the /voice/token response already returns the correct URL.
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
